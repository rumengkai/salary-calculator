page {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #333;
  box-sizing: border-box;
}

/* 毛玻璃卡片 */
.glass-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-radius: 24rpx;
  padding: 40rpx;
  margin: 24rpx 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.glass-card-light {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 16rpx 0;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
}

/* 标题 */
.page-header {
  padding: 40rpx 32rpx 20rpx;
  text-align: center;
}

.page-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 输入区域 */
.input-group {
  margin-bottom: 28rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input-field {
  width: 100%;
  height: 80rpx;
  background: rgba(102, 126, 234, 0.06);
  border: 2rpx solid rgba(102, 126, 234, 0.15);
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  color: #333;
  box-sizing: border-box;
  transition: border-color 0.3s;
}

.input-field:focus {
  border-color: #667eea;
}

.input-unit {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 结果展示 */
.result-section {
  text-align: center;
  padding: 20rpx 0;
}

.result-amount {
  font-size: 64rpx;
  font-weight: 800;
  color: #667eea;
  line-height: 1.2;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.result-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.result-row:last-child {
  border-bottom: none;
}

.result-row-label {
  font-size: 28rpx;
  color: #666;
}

.result-row-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.result-highlight {
  color: #667eea;
  font-weight: 700;
}

/* 按钮 */
.btn-primary {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  margin-top: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

/* 浮动底部按钮 */
.btn-float-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(240, 242, 255, 0.95) 60%, rgba(240, 242, 255, 0));
  z-index: 100;
}

.btn-float-wrap .btn-primary {
  margin-top: 0;
}

.page-bottom-space {
  height: 160rpx;
}

.btn-primary::after {
  border: none;
}

/* 导航网格 */
.nav-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  padding: 0;
}

.nav-item {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 24rpx;
  padding: 40rpx 24rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.nav-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.nav-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.nav-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 标签页 */
.tab-bar {
  display: flex;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 16rpx;
  padding: 6rpx;
  margin: 24rpx 32rpx;
}

.tab-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  border-radius: 12rpx;
  transition: all 0.3s;
}

.tab-item.active {
  background: rgba(255, 255, 255, 0.9);
  color: #667eea;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 表格 */
.table-header {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 2rpx solid rgba(102, 126, 234, 0.2);
}

.table-row {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
}

.table-cell {
  flex: 1;
  font-size: 24rpx;
  text-align: center;
}

.table-cell-header {
  font-size: 22rpx;
  color: #999;
  font-weight: 500;
}

/* 对比卡片 */
.compare-card {
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
}

.compare-card.recommended {
  background: rgba(102, 126, 234, 0.08);
  border: 2rpx solid rgba(102, 126, 234, 0.3);
}

.compare-card.normal {
  background: rgba(0, 0, 0, 0.02);
  border: 2rpx solid rgba(0, 0, 0, 0.06);
}

.badge {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.badge-primary {
  background: rgba(102, 126, 234, 0.15);
  color: #667eea;
}

.badge-gray {
  background: rgba(0, 0, 0, 0.06);
  color: #999;
}

/* 开关选项 */
.switch-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.switch-label {
  font-size: 28rpx;
  color: #333;
}

.switch-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 分段控制 */
.segment-control {
  display: flex;
  background: rgba(102, 126, 234, 0.08);
  border-radius: 12rpx;
  padding: 4rpx;
}

.segment-item {
  flex: 1;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.3s;
}

.segment-item.active {
  background: #667eea;
  color: #fff;
  font-weight: 600;
}

/* 数字输入框 */
.number-input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.number-stepper {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(102, 126, 234, 0.1);
  border-radius: 12rpx;
  font-size: 32rpx;
  color: #667eea;
  font-weight: 600;
}

.number-display {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  min-width: 60rpx;
  text-align: center;
}
