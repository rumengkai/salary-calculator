<view class="page-header">
  <view class="page-title">个税计算器</view>
  <view class="page-subtitle">智能计算 · 一目了然</view>
</view>

<view class="glass-card">
  <view class="nav-grid">
    <view class="nav-item" bindtap="goToSalary">
      <view class="nav-icon">💰</view>
      <view class="nav-label">月度工资</view>
      <view class="nav-desc">累计预扣预缴</view>
    </view>
    <view class="nav-item" bindtap="goToAnnual">
      <view class="nav-icon">📊</view>
      <view class="nav-label">年度汇算</view>
      <view class="nav-desc">综合所得计税</view>
    </view>
    <view class="nav-item" bindtap="goToBonus">
      <view class="nav-icon">🎁</view>
      <view class="nav-label">年终奖</view>
      <view class="nav-desc">两种方式对比</view>
    </view>
    <view class="nav-item" bindtap="goToDeductions">
      <view class="nav-icon">📋</view>
      <view class="nav-label">专项扣除</view>
      <view class="nav-desc">附加扣除配置</view>
    </view>
  </view>
</view>

<!-- 全局配置入口 -->
<view class="glass-card" style="padding:32rpx 40rpx;">
  <view class="input-label" style="margin-bottom:20rpx;font-weight:600;font-size:28rpx;">全局配置（设置一次，各页面自动读取）</view>

  <view class="config-entry" bindtap="goToInsurance">
    <view class="config-left">
      <text class="config-icon">🏥</text>
      <view>
        <view class="config-name">五险一金</view>
        <view class="config-desc" wx:if="{{!insuranceSummary}}">输入基数和比例，自动算出月缴金额</view>
        <view class="config-desc" wx:if="{{insuranceSummary}}">已配置：¥{{insuranceSummary.monthlyTotal}} 元/月</view>
      </view>
    </view>
    <text class="config-arrow">›</text>
  </view>

  <view class="config-entry" bindtap="goToDeductions">
    <view class="config-left">
      <text class="config-icon">📋</text>
      <view>
        <view class="config-name">专项附加扣除</view>
        <view class="config-desc" wx:if="{{!deductionsSummary}}">子女教育、房贷/租金、赡养老人等</view>
        <view class="config-desc" wx:if="{{deductionsSummary}}">已配置：¥{{deductionsSummary.monthlyTotal}} 元/月</view>
      </view>
    </view>
    <text class="config-arrow">›</text>
  </view>
</view>

<!-- 个税知识入口 -->
<view class="glass-card" bindtap="goToGuide" style="display:flex;align-items:center;gap:20rpx;padding:32rpx 40rpx;">
  <view class="nav-icon" style="font-size:44rpx;margin:0;">📖</view>
  <view style="flex:1;">
    <view style="font-size:30rpx;font-weight:600;color:#333;">个税知识速览</view>
    <view style="font-size:24rpx;color:#999;margin-top:4rpx;">了解中国新版个税计算规则与政策要点</view>
  </view>
  <text style="font-size:28rpx;color:#ccc;">›</text>
</view>
