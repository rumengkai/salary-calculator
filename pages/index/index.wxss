.config-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.config-entry:last-child {
  border-bottom: none;
}

.config-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.config-icon {
  font-size: 40rpx;
}

.config-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.config-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.config-arrow {
  font-size: 32rpx;
  color: #bbb;
}

.share-btn {
  position: absolute;
  top: 40rpx;
  right: 32rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 1;
}

.share-btn::after {
  border: none;
}

.share-icon {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}
