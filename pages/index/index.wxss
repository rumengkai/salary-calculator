.config-entry {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
}

.config-entry:last-child {
  border-bottom: none;
}

.config-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.config-icon {
  font-size: 40rpx;
}

.config-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.config-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.config-arrow {
  font-size: 32rpx;
  color: #ccc;
}
